; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters
;
; Playtest-trigger bump 2026-04-19T14:50Z — force a fresh playtest run
; after 15+ merges since 13:43 UTC didn't fire the bot. Concurrency
; lock suspected; this bump pushes directly on main through a
; playtest-path-filtered file.

config_version=5

[application]

config/name="Affoltern Banani Raubzug"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
CurrencyManager="*res://scripts/autoload/currency_manager.gd"
AminosManager="*res://scripts/autoload/aminos_manager.gd"
ComboTracker="*res://scripts/autoload/combo_tracker.gd"
MusicManager="*res://scripts/autoload/music_manager.gd"
SfxManager="*res://scripts/autoload/sfx_manager.gd"
AutoPlaytest="*res://scripts/autoload/auto_playtest.gd"
WaveSimulator="*res://scripts/autoload/wave_simulator.gd"
ProjectilePool="*res://scripts/autoload/projectile_pool.gd"
EnemyPool="*res://scripts/autoload/enemy_pool.gd"
EffectPlayer="*res://scripts/autoload/effect_player.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=0

[gui]

theme/custom="res://assets/fonts/main_theme.tres"

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
