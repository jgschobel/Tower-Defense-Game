[gd_resource type="Theme" load_steps=4 format=3 uid="uid://b6m8n7emoji00"]

; Project default theme. Single point of truth for font / size / outline
; so EVERY Label and Button picks up the cohesive look without each
; script having to call DesignTokens.style_label.
;
; Hierarchy:
;   - default_font: Godot SansSerif + Noto Emoji fallback (emoji glyphs)
;   - default_font_size: 16 (DesignTokens.FONT_LABEL)
;   - Label / outline_size: 3 (DesignTokens.OUTLINE_LABEL) — gives every
;     label a thin dark outline by default. The single biggest cohesion
;     fix per the visual-research agent ("default Arial / no outline is
;     the loudest amateur tell"). Scripts that want a thicker outline
;     (headings, titles) override via add_theme_constant_override.
;   - Label / font_outline_color: warm-dark COL_TEXT_OUTLINE so the
;     outline blends with the warm palette instead of going pure black.
;
; The Noto Emoji .ttf is fetched at CI build time — see
; assets/fonts/README.md. If NotoEmoji.ttf is missing locally, the
; FontFile resource degrades to default-font-only (never crashes).

[ext_resource type="FontFile" path="res://assets/fonts/NotoEmoji.ttf" id="1_emoji"]

[sub_resource type="FontVariation" id="FontVariation_default"]
fallbacks = Array[Font]([ExtResource("1_emoji")])

[resource]
default_font = SubResource("FontVariation_default")
default_font_size = 16
Label/constants/outline_size = 3
Label/colors/font_outline_color = Color(0.05, 0.03, 0.02, 0.95)
Button/constants/outline_size = 2
Button/colors/font_outline_color = Color(0.05, 0.03, 0.02, 0.95)
